          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bobToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/audit", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "audit"] }
          }
        }
